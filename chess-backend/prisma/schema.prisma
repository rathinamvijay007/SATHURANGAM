datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  username         String    @unique
  email            String    @unique
  passwordHash     String
  role             String    @default("USER")   // "USER" | "ADMIN"
  avatar           String?
  rating           Int       @default(1200)
  wins             Int       @default(0)
  losses           Int       @default(0)
  draws            Int       @default(0)
  refreshTokenHash String?   // Hashed refresh token (null after logout)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  whiteGames       Game[]        @relation("WhitePlayer")
  blackGames       Game[]        @relation("BlackPlayer")
  messages         ChatMessage[]

  // Indexes
  @@index([rating])
  @@index([role])
}

// ─────────────────────────────────────────────────────────────────────────────
// GAME
// ─────────────────────────────────────────────────────────────────────────────
model Game {
  id              String    @id @default(uuid())
  whitePlayerId   String
  blackPlayerId   String

  // Status: "WAITING" | "IN_PROGRESS" | "WHITE_WON" | "BLACK_WON" | "DRAW"
  status          String

  // Outcome: "CHECKMATE" | "RESIGNATION" | "TIMEOUT" | "STALEMATE" |
  //          "DRAW_AGREEMENT" | "INSUFFICIENT_MATERIAL" | "FIFTY_MOVES" |
  //          "THREEFOLD_REPETITION"
  outcome         String?

  fen             String    // Current board position as FEN string
  pgn             String    @default("")  // Full game in PGN notation

  timeControl     String    // e.g. "3+2", "5+0", "10+0", "1+0"
  whiteTimeLeftMs Int
  blackTimeLeftMs Int

  startedAt       DateTime?
  finishedAt      DateTime?
  lastMoveAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  whitePlayer     User      @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
  blackPlayer     User      @relation("BlackPlayer", fields: [blackPlayerId], references: [id])
  moves           Move[]
  messages        ChatMessage[]

  // Indexes — critical for history queries and filtering
  @@index([whitePlayerId])
  @@index([blackPlayerId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MOVE
// ─────────────────────────────────────────────────────────────────────────────
model Move {
  id          String   @id @default(uuid())
  gameId      String
  moveNumber  Int
  playerColor String   // "W" or "B"
  notation    String   // SAN notation e.g. "Nf3"
  fenAfter    String   // Board state after this move
  timeLeftMs  Int      // Remaining clock time for moving player

  createdAt   DateTime @default(now())

  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // Index — prevents N+1 when loading moves for a game
  @@index([gameId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CHAT MESSAGE
// ─────────────────────────────────────────────────────────────────────────────
model ChatMessage {
  id        String   @id @default(uuid())
  gameId    String
  senderId  String
  content   String

  createdAt DateTime @default(now())

  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([gameId])
}
